import csv
from pathlib import Path


PROJECT_ROOT = Path(config.get("project_root", "."))
SAMPLESHEET = config["paths"]["samplesheet"]


def load_samplesheet(path):
    sheet = PROJECT_ROOT / path
    if not sheet.exists():
        return {}, {}, []
    with sheet.open("r", encoding="utf-8", newline="") as handle:
        reader = csv.DictReader(handle, delimiter="\t")
        rows = [row for row in reader if row.get("sample_id")]
    r1 = {row["sample_id"]: row["fastq_r1"] for row in rows}
    r2 = {row["sample_id"]: row["fastq_r2"] for row in rows}
    samples = list(r1)
    return r1, r2, samples


FASTQ_R1, FASTQ_R2, SAMPLES = load_samplesheet(SAMPLESHEET)
READS = ["R1", "R2"]


rule all:
    input:
        config.get("targets", ["results/tables/preflight_samplesheet_check.tsv"])


